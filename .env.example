# Copia este archivo a ".env" y rellena tus claves de la TESTNET de Binance.
# El archivo .env está en .gitignore: nunca se sube a git.
#
# Cómo obtener las claves (gratis, dinero ficticio):
#   1. Entra en https://testnet.binance.vision/
#   2. Inicia sesión con tu cuenta de GitHub
#   3. Pulsa "Generate HMAC_SHA256 Key"
#   4. Copia la API Key y la Secret Key aquí abajo
#
# OJO: la testnet se resetea ~1 vez al mes y te repone saldo virtual.

# Exchange a usar (de momento, binance). Cambiar aquí para migrar en el futuro.
EXCHANGE=binance

# True = entorno de pruebas (dinero ficticio). NUNCA pongas False sin hablarlo.
TESTNET=True

# Claves de la testnet
API_KEY=pega_aqui_tu_api_key
API_SECRET=pega_aqui_tu_secret_key

# Par e intervalo por defecto para los experimentos
SYMBOL=BTC/USDT
TIMEFRAME=5m
